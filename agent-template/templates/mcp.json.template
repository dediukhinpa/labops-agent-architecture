{
  "mcpServers": {
    "second_brain-memory": {
      "type": "http",
      "url": "${MCP_HOST}/memory/mcp",
      "headers": { "Authorization": "Bearer ${AGENT_BEARER}" }
    },
    "second_brain-memory_router": {
      "type": "http",
      "url": "${MCP_HOST}/memory_router/mcp",
      "headers": { "Authorization": "Bearer ${AGENT_BEARER}" }
    },
    "second_brain-agent_router": {
      "type": "http",
      "url": "${MCP_HOST}/agent_router/mcp",
      "headers": { "Authorization": "Bearer ${AGENT_BEARER}" }
    }
  }
}
